{
  "pdf_templates": {
    "example": {
      "class": "PdfExample",
      "file": "include/class-pdf-example.php",
      "title": "Example Document",
      "description": "Simple example template with header and footer",
      "features": ["header_footer"],
      "usage": "demo_pdf=example&nonce=NONCE_VALUE"
    },
    "invoice": {
      "class": "PdfInvoice",
      "file": "include/class-pdf-invoice.php",
      "title": "Invoice",
      "description": "Invoice template with business details and items",
      "features": ["header_footer", "table_layout", "business_info"],
      "usage": "demo_pdf=invoice&nonce=NONCE_VALUE"
    },
    "simple": {
      "class": "PdfSimple",
      "file": "include/class-pdf-simple.php",
      "title": "Simple Document",
      "description": "Minimal template without header/footer",
      "features": [],
      "usage": "demo_pdf=simple&nonce=NONCE_VALUE"
    }
  },
  "traits": {
    "header_footer": {
      "file": "include/trait-pdf-header-footer.php",
      "description": "Provides automated header and footer rendering"
    }
  },
  "registry": {
    "description": "Template registry in dispatch.php",
    "location": "include/dispatch.php",
    "registration_example": "PdfRegistry::register('example', 'PdfExample', __DIR__ . '/class-pdf-example.php')"
  }
}
