         *                               4    Quarterly
         * @param mixed $basis The type of day count to use (int) .
         *                         0 or omitted    US (NASD) 30/360
         *                         1               Actual/actual
         *                         2               Actual/360
         *                         3               Actual/365
         *                         4               European 30/360
         *
         * @return float|string
         */
        public static function COUPDAYSNC($settlement, $maturity, $frequency, $basis = \PhpOffice\PhpSpreadsheet\Calculation\Financial\Constants::BASIS_DAYS_PER_YEAR_NASD)
        {
        }
        /**
         * COUPNCD.
         *
         * Returns the next coupon date after the settlement date.
         *
         * Excel Function:
         *        COUPNCD(settlement,maturity,frequency[,basis])
         *
         * @param mixed $settlement The security's settlement date.
