         * @param HTMLPurifier_Token[] $tokens
         * @param HTMLPurifier_Config $config
         * @param HTMLPurifier_Context $context
         * @return array|HTMLPurifier_Token[]
         */
        public function execute($tokens, $config, $context)
        {
        }
    }
